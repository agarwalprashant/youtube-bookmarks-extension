{
  "manifest_version": 3,
  "name": "YouTube Video Bookmarks",
  "version": "1.0",
  "description": "YouTube videos pe bookmarks create karo aur manage karo",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*", "https://learnwith.campusx.in/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://learnwith.campusx.in/*"],
      "js": ["campusx-content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["image.png"],
      "matches": ["https://www.youtube.com/*", "https://learnwith.campusx.in/*"]
    }
  ]
}
